# Copy to .env at the repo root and fill in. Only CEREBRAS_API_KEY is required
# to run the agent; without the JIRA_* / SLACK_ vars the action adapter runs in
# mock mode and returns a fake mock.jira.local URL instead of pushing.

# --- LLM (required for the agent; not needed for POST /api/replay) ---
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
FOUNDRY_MODEL_ID=gemma-4-31b
FOUNDRY_MAX_OUTPUT_TOKENS=2048

# --- Jira push (optional; all four must be set or the adapter mocks) ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT=

# --- Slack push (optional; mocks when unset) ---
SLACK_WEBHOOK_URL=
